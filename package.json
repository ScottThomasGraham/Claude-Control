{
  "name": "claude-control-mcp",
  "version": "0.1.0",
  "description": "Control a remote Windows PC from Claude Code over SSH using only OS-preinstalled tools (PowerShell + .NET). MCP server.",
  "license": "MIT OR Apache-2.0",
  "author": "Scott Graham",
  "repository": { "type": "git", "url": "https://github.com/ScottThomasGraham/Claude-Control.git" },
  "type": "module",
  "bin": {
    "claude-control-mcp": "build/index.js"
  },
  "files": [
    "build",
    "windows",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc && node -e \"import('node:fs').then(f=>f.chmodSync('build/index.js',0o755))\"",
    "watch": "tsc --watch",
    "smoke": "node build/smoke.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
